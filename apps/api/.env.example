# apps/api — NestJS backend environment variables
# Copy this to .env and fill in your values

# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database (must match packages/db/.env)
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/auditflow_ims?schema=public"

# Auth (add in Unit 2)
# JWT_SECRET=change_this_to_a_strong_random_secret
# JWT_EXPIRES_IN=8h

# File storage
UPLOAD_DIR=../../uploads
MAX_FILE_SIZE_MB=50
